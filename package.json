{
  "name": "datelane-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve demo",
    "build": "ng build datelane --configuration production",
    "build:watch": "ng build datelane --watch --configuration development",
    "test": "ng test datelane --watch=false --browsers=ChromeHeadless",
    "test:watch": "ng test datelane",
    "lint": "ng lint",
    "format": "prettier --write \"projects/**/*.{ts,html,scss,json}\"",
    "typecheck": "tsc -p projects/datelane/tsconfig.lib.json --noEmit",
    "pack:lib": "npm run build && cd dist/datelane && npm pack"
  },
  "devDependencies": {
    "@angular/cli": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-browser-dynamic": "^20.0.0",
    "@angular-devkit/build-angular": "^20.0.0",
    "ng-packagr": "^20.0.0",
    "angular-eslint": "^20.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "~5.8.0",
    "zone.js": "~0.15.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "jasmine-core": "~5.7.0",
    "@types/jasmine": "~5.1.0",
    "prettier": "^3.2.0",
    "luxon": "^3.4.0",
    "moment": "^2.30.0",
    "@types/luxon": "^3.4.0",
    "jest-axe": "^9.0.0"
  }
}
